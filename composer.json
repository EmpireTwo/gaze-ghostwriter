{
    "name": "empire2/gaze-ghostwriter",
    "description": "AI-assisted support-mail ghostwriter for Laravel — IMAP inbound, RAG-augmented draft generation, and Gaze-guarded LLM calls.",
    "license": "MIT",
    "type": "library",
    "keywords": ["laravel", "ai", "llm", "support", "imap", "ghostwriter", "gaze", "pii", "livewire"],
    "homepage": "https://github.com/EmpireTwo/gaze-ghostwriter",
    "support": {
        "issues": "https://github.com/EmpireTwo/gaze-ghostwriter/issues",
        "source": "https://github.com/EmpireTwo/gaze-ghostwriter"
    },
    "authors": [
        {
            "name": "Markus Gottschau",
            "email": "hello@lordeagle.ie",
            "homepage": "https://github.com/EmpireTwo"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "illuminate/console": "^12.0",
        "illuminate/contracts": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/notifications": "^12.0",
        "illuminate/queue": "^12.0",
        "illuminate/support": "^12.0",
        "laravel/ai": "^0.4.3",
        "livewire/livewire": "^4.0",
        "empiretwo/gaze-laravel": "^0.6",
        "symfony/mailer": "^7.0",
        "symfony/mime": "^7.0",
        "webklex/laravel-imap": "^6.2"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pennant": "^1.0",
        "laravel/pint": "^1.17",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^2.0",
        "spatie/laravel-permission": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Empire2\\GazeGhostwriter\\": "src/",
            "Empire2\\GazeGhostwriter\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Empire2\\GazeGhostwriter\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Empire2\\GazeGhostwriter\\GazeGhostwriterServiceProvider"]
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse",
        "format": "pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "empiretwo/gaze-laravel": true,
            "pestphp/pest-plugin": true
        }
    }
}
